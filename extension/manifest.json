{
  "manifest_version": 3,
  "name": "H1B Checker for LinkedIn Jobs",
  "version": "1.0.0",
  "description": "Show H1B visa sponsorship status on LinkedIn job listings based on official DOL LCA data.",
  "permissions": [],
  "host_permissions": [
    "https://www.linkedin.com/jobs/*",
    "https://h1bchecker-production.up.railway.app/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/*"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "author": "ggggzj",
  "homepage_url": "https://github.com/ggggzj/H1B_Checker"
}
